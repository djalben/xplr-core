# ===================================
# XPLR - Environment Variables
# ===================================
# Copy to .env and fill in values. Do not commit .env.

# --- DATABASE CONNECTIONS (Supabase) ---
# POSTGRES_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"
# DATABASE_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# --- SUPABASE KEYS ---
# SUPABASE_URL="https://PROJECT_REF.supabase.co"
# SUPABASE_ANON_KEY="your_supabase_anon_key"
# SUPABASE_SERVICE_KEY="your_supabase_service_role_key"  # Required for Storage uploads (Dashboard → Settings → API → service_role)

# --- FRONTEND SYNC (Vite) ---
# VITE_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# --- WALLESTER API ---
WALLESTER_API_KEY=your_wallester_api_key
WALLESTER_API_URL=https://api.wallester.com/v1

# --- WALLESTER WEBHOOK SECURITY ---
# Список разрешенных IP-адресов Wallester для webhook (через запятую, поддерживается CIDR нотация)
# Пример: WALLESTER_WEBHOOK_IPS="192.168.1.1,10.0.0.0/8,203.0.113.0/24"
# Оставьте пустым для development (не рекомендуется для production)
WALLESTER_WEBHOOK_IPS=
# Секретный ключ для проверки подписи webhook (HMAC-SHA256)
# Должен совпадать с ключом, настроенным в панели Wallester
WALLESTER_WEBHOOK_SECRET=

# --- SECURITY ---
JWT_SECRET=your_highly_secret_and_long_jwt_key_here

# --- SERVER ---
PORT=8080

# --- TELEGRAM (optional; enables real notifications) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_ADMIN_ID=your_telegram_user_id
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- VLESS VPN (3X-UI Panel — MHSanaei) ---
XPANEL_URL=https://109.120.157.144:2053
XPANEL_USERNAME=your_panel_username
XPANEL_PASSWORD=your_panel_password
XPANEL_INBOUND_ID=1
XPANEL_SERVER_IP=109.120.157.144
XPANEL_SERVER_PORT=443
XPANEL_SNI=www.microsoft.com
XPANEL_REALITY_PUBLIC_KEY=your_x25519_public_key
XPANEL_REALITY_SHORT_ID=your_short_id
XPANEL_FLOW=xtls-rprx-vision

# --- VPN SERVER LIMITS ---
VPN_SERVER_TRAFFIC_LIMIT_GB=30
VPN_SERVER_MONTHLY_COST=4.94

# --- DEV MODE (skip payment for testing) ---
DEV_MODE=true

# --- AEZA HOSTING (balance monitoring) ---
AEZA_API_KEY=6407_2810842ca135a21c8d58be75a32e4811
AEZA_SERVER_ID=1767112
AEZA_BALANCE_THRESHOLD=2
