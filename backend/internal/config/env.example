LOG_LEVEL=debug2
LOG_PLAIN=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

POSTGRES_DSN=postgres://admin:password@localhost:5433/xplr?sslmode=disable
JWT_SECRET_TOKEN=your-super-secret-jwt-key-change-in-production

# HTTP server
SERVER_HOST=0.0.0.0
SERVER_PORT=8081

# SMTP (optional; if SMTP_HOST is empty -> Noop mailer, no emails sent)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=admin@xplr.pro
SMTP_PASS=your-app-password-here
SMTP_FROM=admin@xplr.pro

# Store providers
MOBIMATTER_API_KEY=
MOBIMATTER_API_URL=https://api.mobimatter.com/mobimatter/api/v2

# 3X-UI / XPanel (VLESS+Reality) provider
XPANEL_URL=
XPANEL_BASE_PATH=/panel
XPANEL_USERNAME=
XPANEL_PASSWORD=
XPANEL_INBOUND_ID=1
XPANEL_SERVER_IP=
XPANEL_SERVER_PORT=443
XPANEL_SNI=www.microsoft.com
XPANEL_REALITY_PUBLIC_KEY=
XPANEL_REALITY_SHORT_ID=
XPANEL_FLOW=xtls-rprx-vision