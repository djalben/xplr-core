# ═══════════════════════════════════════════════════
# XPLR Backend — Environment Variables
# ═══════════════════════════════════════════════════

# Database
DATABASE_URL=postgres://user:password@localhost:5432/xplr?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-here

# SMTP (Zoho Mail — admin@xplr.pro)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=admin@xplr.pro
SMTP_PASS=your-app-password-here
SMTP_FROM=admin@xplr.pro

# Telegram Bot (admin notifications, transaction alerts)
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz

# Frontend domain (used in email links)
APP_DOMAIN=https://xplr.pro

# CORS
ALLOWED_ORIGINS=https://xplr.pro,http://localhost:5173
